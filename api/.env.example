# AXIOM API deployment env
# Put these in your backend host environment, or copy to api/.env for local dev.

# Required: API bind settings.
API_HOST=0.0.0.0
API_PORT=8080
AXIOM_DEMO_MODE=false

# Required in production if the API should persist analytics/jobs.
DATABASE_URL=postgres://axiom:axiom@localhost:5432/axiom
REDIS_URL=redis://localhost:6379

# Required for server-side Solana/keeper jobs if run from the API host.
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_WS_URL=wss://api.devnet.solana.com
ANCHOR_PROVIDER_WALLET=/secure/path/to/server-wallet.json

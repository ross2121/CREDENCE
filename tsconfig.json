{
  "compilerOptions": {
    "types": ["mocha", "chai", "node"],
    "typeRoots": ["./node_modules/@types"],
    "lib": ["es2015"],
    "module": "commonjs",
    "target": "es6",
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": [
    "axiom-agents/**/*.ts",
    "integrations/**/*.ts",
    "scripts/**/*.ts",
    "sdk/**/*.ts",
    "tests/**/*.ts"
  ],
  "exclude": ["app", "api", "node_modules"]
}
